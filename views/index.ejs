<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Groceries Inventory App</title>
  </head>
  <body>
    <h1>Groceries Inventory</h1>

    <div>
      <h2>Categories</h2>

      <ul>
        <% categories.map(category => { %>
          <li><a href="/category/<%= category.id %>"><%= category.name %></a></li>
        <% }) %>
      </ul>
    </div>
  </body>
</html>